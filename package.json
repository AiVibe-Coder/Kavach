{
  "name": "kavach",
  "version": "1.0.0",
  "description": "Secure local Todo & Password Manager with iOS access",
  "main": "main.js",
  "scripts": {
    "start": "vite build && electron .",
    "dev": "concurrently \"vite --port 5173\" \"wait-on http://localhost:5173 && cross-env ELECTRON_DEV=true electron .\"",
    "build": "node scripts/gen-icons.js && vite build && electron-builder --mac --dir",
    "dist": "node scripts/gen-icons.js && vite build && electron-builder --mac"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.2.0",
    "electron-builder": "^24.13.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.kavach.app",
    "productName": "KaVach",
    "copyright": "KaVach — कवच",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "electron/**/*"
    ],
    "extraResources": [],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/KaVach.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "darkModeSupport": true,
      "identity": null
    },
    "dmg": {
      "title": "KaVach",
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
