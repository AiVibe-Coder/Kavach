{
  "manifest_version": 3,
  "name": "KaVach Passwords",
  "version": "1.0.0",
  "description": "Fill passwords from your KaVach vault — Chrome, Firefox, Edge, Brave only. Does not affect Safari.",
  "icons": {
    "16":  "icons/16.png",
    "32":  "icons/32.png",
    "48":  "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/16.png",
      "32":  "icons/32.png",
      "48":  "icons/48.png",
      "128": "icons/128.png"
    },
    "default_title": "KaVach Passwords"
  },
  "options_page": "options.html",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["http://127.0.0.1:3847/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
